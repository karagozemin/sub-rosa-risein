{
  "name": "sub-rosa-risein",
  "version": "1.0.0",
  "private": true,
  "description": "Independent Stellar Journey to Mastery Orange Belt mini dApp.",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter @sub-rosa/web dev",
    "build": "pnpm --filter @sub-rosa/web build",
    "preview": "pnpm --filter @sub-rosa/web preview",
    "typecheck": "pnpm --filter @sub-rosa/web typecheck",
    "test": "pnpm --filter @sub-rosa/sdk test && pnpm --filter @sub-rosa/tlock test:unit",
    "contract:build": "stellar contract build --package sub-rosa-risein-contract",
    "contract:test": "cargo test -p sub-rosa-risein-contract",
    "contract:deploy:testnet": "bash scripts/deploy-testnet.sh"
  }
}
