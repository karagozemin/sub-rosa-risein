{
  "name": "@sub-rosa/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SDK for integrating Sub Rosa sealed coordination rounds into Stellar and Soroban apps.",
  "keywords": [
    "stellar",
    "soroban",
    "privacy",
    "commit-reveal",
    "drand",
    "sealed-auctions",
    "coordination"
  ],
  "repository": {
    "type": "git",
