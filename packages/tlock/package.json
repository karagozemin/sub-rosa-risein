  "keywords": [
    "drand",
    "tlock",
    "privacy",
    "timelock-encryption",
    "commit-reveal",
    "stellar",
    "soroban"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/karagozemin/sub-rosa-risein.git",
    "directory": "packages/tlock"
  },
  "main": "src/index.ts",
  "scripts": {
    "test": "node --import tsx --test src/commitment.test.ts src/auditor.test.ts src/bls.test.ts src/seal.test.ts",
    "test:unit": "node --import tsx --test src/commitment.test.ts src/auditor.test.ts src/bls.test.ts",
    "test:seal": "node --import tsx --test src/seal.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
