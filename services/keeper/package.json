{
  "name": "@sub-rosa/keeper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Permissionless reveal keeper: waits for Drand round R, opens the reveal window with R's real signature, then decrypts and reveals every sealed bid. Idempotent; no relayer, no agent, no mock.",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --import tsx src/run.ts",
    "watch": "node --import tsx src/watch.ts",
    "test": "node --import tsx --test src/keeper.test.ts src/watch.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@sub-rosa/sdk": "workspace:*",
    "@sub-rosa/tlock": "workspace:*"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "^15.1.0",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
